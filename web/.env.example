NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Admin da plataforma (rotas /api/admin/* e /admin/*): e-mails ou UUIDs separados por vírgula.
SYSTEM_ADMIN_EMAILS=seu@email.com
# SYSTEM_ADMIN_USER_IDS=

# Gravar/editar planos comerciais no Supabase (só servidor; nunca NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=
# Opcional: nome no cabeçalho do painel (ex.: Clínica Saúde)
NEXT_PUBLIC_CLINIC_NAME=

# OAuth Google: em Supabase → Authentication → Providers → Google (ativar + Client ID/Secret);
# em URL Configuration inclua: http://localhost:3000/auth/callback, /login, /login/admin,
# /cadastro e /redefinir-senha (e o mesmo domínio em produção). Sem isto: "provider is not enabled".
# (e os URLs em produção). Erros de auth redirecionam para /login.
# Se a criação da clínica falhar por RLS, execute supabase/rls_clinic_insert_owner.sql no SQL Editor.

# n8n: após INSERT/UPDATE em agendamentos (ou sessões), chamar POST /api/agendamentos-sync
# com Authorization: Bearer <este valor> ou cabeçalho x-agendamentos-sync-secret
AGENDAMENTOS_SYNC_SECRET=gere-um-segredo-longo-aleatorio

# Backend Express (obrigatório para /api/whatsapp/* no Next fazer proxy).
# Na raiz do repositório, npm run dev inicia Next + Express. Só o frontend: npm run dev:frontend.
# O Express usa PORT (default 3001) — veja backend/server.js e .env na raiz.
BACKEND_API_URL=http://localhost:3001

# Evolution API (só servidor — NÃO use prefixo NEXT_PUBLIC_ para não expor a chave no browser)
EVOLUTION_API_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_KEY=
# Webhook n8n — URL completa do nó "Webhook" do fluxo (produção).
# Fluxo no repositório: Clinica atualizada (id kCX2LfxJrdYWB0vk). Testes: …/webhook/…-test
# Se omitir, usa https://n8n.vps7846.panel.icontainer.cloud/webhook/a9a0aa31-2d90-45ad-8da2-536c499768d8
N8N_WEBHOOK_URL=https://n8n.vps7846.panel.icontainer.cloud/webhook/a9a0aa31-2d90-45ad-8da2-536c499768d8
# Opcional: só o host, se não quiser repetir o path (o path UUID fica em código)
# N8N_PUBLIC_BASE_URL=https://n8n.vps7846.panel.icontainer.cloud