        "jsCode": "const appts = $input.all().map((i) => i.json);\nconst base = $('Parse Evolution').first().json;\nif (!appts.length) {\n  return [{ json: { ...base, wa_reply: 'Não encontrámos consultas ativas para este número. Digite agendar para marcar.' } }];\n}\nconst fmt = (iso) => { try { return new Date(iso).toLocaleString('pt-BR'); } catch { return iso; } };\nconst lines = appts.map((a) => '• id ' + a.id + ' | ' + fmt(a.starts_at) + ' | ' + (a.profissional || ''));\nconst wa_reply = 'As suas consultas:\\n' + lines.join('\\n') + '\\n\\nPara remarcar, envie: reagendar + nova data/hora (vamos confirmar manualmente ou no próximo passo do robô).';\nreturn [{ json: { ...base, wa_reply } }];"
