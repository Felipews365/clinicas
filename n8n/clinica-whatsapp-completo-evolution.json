      "parameters": {
        "jsCode": "const rows = $input.all().map((i) => i.json);\nconst base = $('Parse Evolution').first().json;\nif (!rows.length) {\n  return [{ json: { ...base, wa_reply: 'Não há profissionais ativos cadastrados. Ligue para a clínica.' } }];\n}\nconst lines = rows.map((r) => '• ' + r.name + (r.specialty ? ' — ' + r.specialty : '') + ' (id: ' + r.id + ')');\nconst wa_reply = 'Profissionais disponíveis:\\n' + lines.join('\\n') + '\\n\\nEnvie data, horário preferido e o id do profissional para verificarmos vagas.';\nreturn [{ json: { ...base, wa_reply } }];"
