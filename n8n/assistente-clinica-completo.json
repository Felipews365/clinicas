      "id": "a1c1e1f1-2222-4222-8222-222222222222",
      "name": "Normalizar entrada",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [220, 300]
    },
    {
      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst text = String(j.message || '').toLowerCase();\nlet intent = 'info';\nif (/agendar|marcar|marca[cç][aã]o|hor[aá]rio|consulta|quero ver|dispon[ií]vel/.test(text)) intent = 'schedule';\nif (/cancelar|desmarcar|anular/.test(text)) intent = 'cancel';\nif (/reagendar|remarcar|mudar.{0,8}(data|hor[aá]rio)/.test(text)) intent = 'reschedule';\nreturn [{ json: { ...j, intent } }];"
      },
      "id": "a1c1e1f1-3333-4333-8333-333333333333",
      "name": "Classificar intenção (Code)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "ic1",
              "leftValue": "={{ $json.intent }}",
              "rightValue": "schedule",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "a1c1e1f1-4444-4444-8444-444444444444",
      "name": "É agendamento?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [660, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT id, name, specialty, sort_order FROM public.professionals WHERE clinic_id = '{{ $json.clinic_id }}'::uuid AND is_active = true ORDER BY sort_order, name",
        "options": {}
      },
      "id": "a1c1e1f1-5555-4555-8555-555555555555",
      "name": "Listar profissionais",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [900, 180],
      "credentials": {
        "postgres": {
          "name": "Supabase Postgres"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const pros = $input.all().map((i) => i.json);\nconst base = $('Classificar intenção (Code)').first().json;\nreturn [\n  {\n    json: {\n      ...base,\n      professionals: pros,\n    },\n  },\n];"
      },
      "id": "a1c1e1f1-5a5a-4555-8555-55555555555a",
      "name": "Agregar profissionais (1 item)",
