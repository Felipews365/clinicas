              "id": "r1",
              "name": "reply",
              "value": "={{ JSON.stringify({ ok: true, intent: 'schedule', clinic_id: $json.clinic_id, phone: $json.phone, professionals: $json.professionals, hint: 'Próximo: slots + INSERT (ver consultorio-agendar-webhook.json)' }) }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "a1c1e1f1-6666-4666-8666-666666666666",
