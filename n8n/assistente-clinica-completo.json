      "id": "a1c1e1f1-8888-4888-8888-888888888888",
      "name": "É cancelar ou remarcar?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [900, 420]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT a.id, a.starts_at, a.ends_at, a.service_name, p.name AS professional_name FROM public.appointments a JOIN public.patients pt ON pt.id = a.patient_id JOIN public.professionals p ON p.id = a.professional_id WHERE a.clinic_id = '{{ $('Classificar intenção (Code)').first().json.clinic_id }}'::uuid AND pt.phone = '{{ String($('Classificar intenção (Code)').first().json.phone || '').replace(/'/g, \"''\") }}' AND a.status = 'scheduled' ORDER BY a.starts_at",
        "options": {}
      },
      "id": "a1c1e1f1-9999-4999-8999-999999999999",
