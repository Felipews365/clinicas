      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO public.whatsapp_sessions (clinic_id, phone, needs_human, staff_handling, last_message_preview, updated_at)\nVALUES (\n  '{{ $json.clinic_id }}'::uuid,\n  '{{ String($json.phone || \"\").replace(/'/g, \"''\") }}',\n  true,\n  false,\n  left('{{ String($json.message || \"\").replace(/'/g, \"''\") }}', 500),\n  now()\n)\nON CONFLICT (clinic_id, phone) DO UPDATE SET\n  needs_human = true,\n  last_message_preview = EXCLUDED.last_message_preview,\n  updated_at = now();",
        "options": {}
