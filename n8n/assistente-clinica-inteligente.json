    {
      "parameters": {
        "jsCode": "const j = $input.first().json;\nconst text = String(j.message || '').toLowerCase();\nconst wantsHuman = /falar com (um )?humano|atendente|pessoa real|operador|falar com algu[eé]m|quero um humano/.test(text);\nlet intent = 'info';\nif (/agendar|marcar|marca[cç][aã]o|hor[aá]rio|consulta|quero ver|dispon[ií]vel/.test(text)) intent = 'schedule';\nif (/cancelar|desmarcar|anular/.test(text)) intent = 'cancel';\nif (/reagendar|remarcar|mudar.{0,8}(data|hor[aá]rio)/.test(text)) intent = 'reschedule';\nreturn [{ json: { ...j, intent, wants_human: wantsHuman } }];"
      },
