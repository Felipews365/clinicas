# ============================================================================
# VARIÁVEIS DE AMBIENTE - SISTEMA MULTI-TENANT WHATSAPP
# ============================================================================

# ============================================================================
# EVOLUTION API
# ============================================================================
# URL da instância Evolution API
EVOLUTION_API_URL=https://api.evolution-api.com

# Chave de API para autenticação na Evolution API
EVOLUTION_API_KEY=seu_evolution_api_key_aqui

# ============================================================================
# SUPABASE
# ============================================================================
# URL do projeto Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave de serviço Supabase (usar apenas no backend, NUNCA no frontend)
SUPABASE_SERVICE_KEY=seu_service_key_aqui

# Chave pública Supabase (se necessário para cliente)
SUPABASE_ANON_KEY=sua_anon_key_aqui

# ============================================================================
# WEBHOOK EVOLUTION (URL interna da sua API para receber eventos)
# ============================================================================
EVOLUTION_WEBHOOK_URL=https://seu-backend.com/api/webhooks/evolution

# Segredo opcional para validação do webhook recebido
EVOLUTION_WEBHOOK_SECRET=

# Opcional: encaminhar eventos recebidos para n8n após persistir no backend
N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/seu-endpoint

# Token de autenticação da API n8n (opcional)
N8N_API_KEY=seu_n8n_api_key_opcional

# ============================================================================
# ANTHROPIC / CLAUDE API
# ============================================================================
# Chave de API da Anthropic para usar Claude como agente IA
ANTHROPIC_API_KEY=sk-ant-sua_api_key_aqui

# ============================================================================
# ASAAS (Pagamentos)
# ============================================================================
# Token de autenticação Asaas para webhooks e API
ASAAS_TOKEN=seu_asaas_token_aqui

# ============================================================================
# SERVIDOR EXPRESS (Backend)
# ============================================================================
# Porta do servidor Express
PORT=3001

# Ambiente (development, production)
NODE_ENV=development

# ============================================================================
# LOGGING
# ============================================================================
# Nível de log (debug, info, warn, error)
LOG_LEVEL=info
